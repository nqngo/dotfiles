[init]
	defaultBranch = main
[gpg]
	format = ssh
[user]
	signingkey = {{ onepasswordRead "op://dotfiles/ssh_my/public_key" }}
	name = {{ onepasswordRead "op://dotfiles/ssh_my/name" }}
	email = {{ onepasswordRead "op://dotfiles/ssh_my/email" }}
[core]
{{- if eq .chezmoi.os "windows" }}
	editor = code -n -w
{{- end }}
{{- if eq .chezmoi.os "linux" }}
	editor = vim
{{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
	sshCommand = "ssh.exe"
{{- end }}
{{- end }}
	eol = lf
	autocrlf = input
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
{{- if eq .chezmoi.os "windows" }}
	program = {{ env "USERPROFILE" }}/AppData/Local/Microsoft/WindowsApps/op-ssh-sign.exe
{{- end }}
{{- if eq .chezmoi.os "linux" }}
{{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
	program = {{ output "wslpath" (output "powershell.exe" "-NoProfile" "-NonInteractive" "-Command" "$env:LOCALAPPDATA" | trim) | trim }}/Microsoft/WindowsApps/op-ssh-sign-wsl.exe
{{- end }}
{{- end }}
[tag]
	gpgsign = true
[commit]
	gpgsign = true
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[log]
	showSignature = true
